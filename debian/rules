#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_build:
	cargo build --release

override_dh_auto_test:
	cargo test

override_dh_auto_install:
	mkdir -p debian/acmers/usr/bin
	install -m755 target/release/acmers debian/acmers/usr/bin/
	mkdir -p debian/acmers/usr/share/man/man1
	cp debian/acmers.1 debian/acmers/usr/share/man/man1/
	mkdir -p debian/acmers/lib/systemd/system
	cp debian/acmers.service debian/acmers/lib/systemd/system/
	cp debian/acmers.timer debian/acmers/lib/systemd/system/
